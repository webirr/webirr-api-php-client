{
    "name": "webirr/webirr",
    "type": "library",
    "version": "2.1.0",
    "description": "Official PHP Client Library for WeBirr Payment Gateway APIs",
    "keywords": ["ethiopia", "fintech"],
    "homepage": "https://github.com/webirr/webirr-api-php-client",
    "license": "MIT",
    "authors": [
        {
            "name": "WeBirr",
            "email": "tech@webirr.net",
            "homepage": "https://webirr.net"
        }
    ],
    "require": {
        "php": ">=7.2.5",
        "guzzlehttp/guzzle": "^7.9",
        "guzzlehttp/psr7": "^2.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6.33 || ^10.5.62 || ^11.5.50 || ^12.5.8"
    },
    "autoload": {
        "psr-4": {
            "WeBirr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WeBirr\\": "src/",
            "WeBirr\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit tests/WeBirrTest.php",
        "test:testenv": "vendor/bin/phpunit tests/WeBirrTest_ext.php"
    }
}
